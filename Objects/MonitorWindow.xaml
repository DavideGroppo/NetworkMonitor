<Window x:Class="NetworkMonitor.MonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stato Rete" Height="350" Width="450" WindowStyle="ToolWindow" AllowsTransparency="False"
        Background="Black" Topmost="False" ShowInTaskbar="False">

  <Border CornerRadius="12" Background="#F3F3F3" BorderBrush="#CCCCCC" BorderThickness="1">
    <Grid Margin="15">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" x:Name="TxtTitle" Text="Connessione Wi-Fi" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

      <ListView Grid.Row="1" x:Name="NetworkListView" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="ip" Width="100" DisplayMemberBinding="{Binding ip}" />
            <GridViewColumn Header="rtt (ms)" Width="70" DisplayMemberBinding="{Binding rtt}" />
            <GridViewColumn Header="status" Width="110" DisplayMemberBinding="{Binding status}" />
            <GridViewColumn Header="ttl" Width="70" DisplayMemberBinding="{Binding ttl}" />
          </GridView>
        </ListView.View>
      </ListView>

    </Grid>
  </Border>
</Window>